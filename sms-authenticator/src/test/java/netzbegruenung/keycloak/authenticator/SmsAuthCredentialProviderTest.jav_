package netzbegruenung.keycloak.authenticator;

import netzbegruenung.keycloak.authenticator.credentials.SmsAuthCredentialData;
import netzbegruenung.keycloak.authenticator.credentials.SmsAuthCredentialModel;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Nested;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.keycloak.credential.CredentialInput;
import org.keycloak.credential.CredentialModel;
import org.keycloak.credential.CredentialTypeMetadata;
import org.keycloak.credential.CredentialTypeMetadataContext;
import org.keycloak.models.KeycloakSession;
import org.keycloak.models.RealmModel;
import org.keycloak.models.UserCredentialModel;
import org.keycloak.models.UserModel;
import org.keycloak.models.credential.UserCredentialStore;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import java.io.IOException;
import java.util.stream.Stream;

import static org.assertj.core.api.Assertions.assertThat;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.ArgumentMatchers.anyString;
import static org.mockito.Mockito.mock;
import static org.mockito.Mockito.when;

@DisplayName("SmsAuthCredentialProvider")
@ExtendWith(MockitoExtension.class)
class SmsAuthCredentialProviderTest {

    private SmsAuthCredentialProvider provider;
    @Mock
    private KeycloakSession session;
    @Mock
    private RealmModel realm;
    @Mock
    private UserModel user;
    @Mock
    private UserCredentialStore credentialStore;

    @BeforeEach
    void setUp() {
        provider = new SmsAuthCredentialProvider(session);
    }

    @Nested
    @DisplayName("Credential type")
    class CredentialType {

        @Test
        @DisplayName("should return correct type")
        void shouldReturnCorrectType() {
            assertThat(provider.getType()).isEqualTo("mobile-number");
        }

        @Test
        @DisplayName("should support mobile-number credential type")
        void shouldSupportMobileNumberCredentialType() {
            assertThat(provider.supportsCredentialType("mobile-number")).isTrue();
        }

        @Test
        @DisplayName("should not support other credential types")
        void shouldNotSupportOtherCredentialTypes() {
            assertThat(provider.supportsCredentialType("other-type")).isFalse();
        }
    }

    @Nested
    @DisplayName("Credential validation")
    class CredentialValidation {

        @Test
        @DisplayName("should return false for null credential input")
        void shouldReturnFalseForNullCredentialInput() {
            assertThat(provider.isValid(realm, user, null)).isFalse();
        }

        @Test
        @DisplayName("should return false for wrong credential type")
        void shouldReturnFalseForWrongCredentialType() {
            UserCredentialModel wrongTypeInput = new UserCredentialModel("id", "wrong-type", "response");
            assertThat(provider.isValid(realm, user, wrongTypeInput)).isFalse();
        }

        @Test
        @DisplayName("should return false for null challenge response")
        void shouldReturnFalseForNullChallengeResponse() {
            UserCredentialModel input = new UserCredentialModel("id", "mobile-number", null);
            assertThat(provider.isValid(realm, user, input)).isFalse();
        }
    }

    @Nested
    @DisplayName("Credential configuration check")
    class CredentialConfigurationCheck {

        @Test
        @DisplayName("should return false for unsupported credential type")
        void shouldReturnFalseForUnsupportedCredentialType() {
            assertThat(provider.isConfiguredFor(realm, user, "unsupported-type")).isFalse();
        }

        @Test
        @DisplayName("should return true when credential is configured")
        void shouldReturnTrueWhenCredentialIsConfigured() {
            when(user.credentialManager()).thenReturn(credentialStore);
            CredentialModel model = new CredentialModel();
            model.setType("mobile-number");
            when(credentialStore.getStoredCredentialsByTypeStream("mobile-number"))
                .thenReturn(Stream.of(model));

            assertThat(provider.isConfiguredFor(realm, user, "mobile-number")).isTrue();
        }

        @Test
        @DisplayName("should return false when credential is not configured")
        void shouldReturnFalseWhenCredentialIsNotConfigured() {
            when(user.credentialManager()).thenReturn(credentialStore);
            when(credentialStore.getStoredCredentialsByTypeStream("mobile-number"))
                .thenReturn(Stream.empty());

            assertThat(provider.isConfiguredFor(realm, user, "mobile-number")).isFalse();
        }
    }

    @Nested
    @DisplayName("Credential type metadata")
    class CredentialTypeMetadata {

        @Test
        @DisplayName("should return correct credential type metadata")
        void shouldReturnCorrectCredentialTypeMetadata() {
            CredentialTypeMetadataContext context = mock(CredentialTypeMetadataContext.class);
            CredentialTypeMetadata metadata = provider.getCredentialTypeMetadata(context);

            assertThat(metadata.getType()).isEqualTo("mobile-number");
            assertThat(metadata.getCategory()).isEqualTo(CredentialTypeMetadata.Category.TWO_FACTOR);
        }
    }

    @Nested
    @DisplayName("Credential model conversion")
    class CredentialModelConversion {

        @Test
        @DisplayName("should convert credential model to SmsAuthCredentialModel")
        void shouldConvertCredentialModelToSmsAuthCredentialModel() throws IOException {
            String mobileNumber = "+491761234567";
            CredentialModel model = new CredentialModel();
            model.setCredentialData(
                org.keycloak.util.JsonSerialization.writeValueAsString(
                    new SmsAuthCredentialData(mobileNumber)
                )
            );
            model.setType("mobile-number");

            SmsAuthCredentialModel result = provider.getCredentialFromModel(model);

            assertThat(result).isNotNull();
            assertThat(result.getSmsAuthenticatorData().getMobileNumber()).isEqualTo(mobileNumber);
        }
    }

    @Nested
    @DisplayName("Disableable credential types")
    class DisableableCredentialTypes {

        @Test
        @DisplayName("should return empty stream for disableable credential types")
        void shouldReturnEmptyStreamForDisableableCredentialTypes() {
            Stream<String> result = provider.getDisableableCredentialTypesStream(realm, user);

            assertThat(result).isEmpty();
        }
    }
}
