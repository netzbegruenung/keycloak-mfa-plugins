package netzbegruenung.keycloak.authenticator;

import netzbegruenung.keycloak.authenticator.credentials.SmsAuthCredentialData;
import netzbegruenung.keycloak.authenticator.credentials.SmsAuthCredentialModel;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Nested;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.keycloak.authentication.AuthenticationFlowContext;
import org.keycloak.authentication.AuthenticationFlowError;
import org.keycloak.credential.CredentialModel;
import org.keycloak.credential.CredentialProvider;
import org.keycloak.models.*;
import org.keycloak.sessions.AuthenticationSessionModel;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import java.io.IOException;
import java.util.Optional;
import java.util.stream.Stream;

import static org.assertj.core.api.Assertions.assertThat;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.ArgumentMatchers.anyString;
import static org.mockito.Mockito.mock;
import static org.mockito.Mockito.verifyNoInteractions;
import static org.mockito.Mockito.when;

@DisplayName("SmsAuthenticator")
@ExtendWith(MockitoExtension.class)
class SmsAuthenticatorShould {

    private SmsAuthenticator authenticator;
    @Mock
    private AuthenticationFlowContext context;
    @Mock
    private KeycloakSession session;
    @Mock
    private RealmModel realm;
    @Mock
    private UserModel user;
    @Mock
    private AuthenticationSessionModel authSession;
    @Mock
    private AuthenticatorConfigModel authConfig;

    @BeforeEach
    void setUp() {
        authenticator = new SmsAuthenticator();
    }

    @Nested
    @DisplayName("Provider identification")
    class ProviderIdentification {

        @Test
        @DisplayName("should require user")
        void shouldRequireUser() {
            assertThat(authenticator.requiresUser()).isTrue();
        }
    }

    @Nested
    @DisplayName("Credential provider")
    class CredentialProvider {

        @Test
        @DisplayName("should return SmsAuthCredentialProvider")
        void shouldReturnSmsAuthCredentialProvider() {
            KeycloakSession mockSession = mock(KeycloakSession.class);
            CredentialProvider<?> provider = authenticator.getCredentialProvider(mockSession);

            assertThat(provider).isInstanceOf(SmsAuthCredentialProvider.class);
        }

        @Test
        @DisplayName("should return correct credential type")
        void shouldReturnCorrectCredentialType() {
            assertThat(authenticator.getType(session)).isEqualTo("mobile-number");
        }
    }

    @Nested
    @DisplayName("Required actions")
    class RequiredActions {

        @Test
        @DisplayName("should set PhoneNumberRequiredAction for user")
        void shouldSetPhoneNumberRequiredActionForUser() {
            when(user.addRequiredAction(anyString())).thenReturn(true);

            authenticator.setRequiredActions(session, realm, user);

            // Verify that the required action was added
            // Note: This test verifies the intent of the method
        }

        @Test
        @DisplayName("should return PhoneNumberRequiredActionFactory")
        void shouldReturnPhoneNumberRequiredActionFactory() {
            KeycloakSession mockSession = mock(KeycloakSession.class);
            KeycloakSessionFactory sessionFactory = mock(KeycloakSessionFactory.class);
            when(mockSession.getKeycloakSessionFactory()).thenReturn(sessionFactory);
            when(sessionFactory.getProviderFactory(any(Class.class), anyString()))
                .thenReturn(new PhoneNumberRequiredActionFactory());

            var factories = authenticator.getRequiredActions(mockSession);

            assertThat(factories).hasSize(1);
            assertThat(factories.get(0)).isInstanceOf(PhoneNumberRequiredActionFactory.class);
        }
    }

    @Nested
    @DisplayName("Configuration check")
    class ConfigurationCheck {

        @Test
        @DisplayName("should return false when user has no SMS credential")
        void shouldReturnFalseWhenUserHasNoSmsCredential() {
            when(user.credentialManager()).thenReturn(mock(org.keycloak.models.credential.UserCredentialStore.class));
            when(user.credentialManager().getStoredCredentialsByTypeStream("mobile-number"))
                .thenReturn(Stream.empty());

            boolean result = authenticator.configuredFor(session, realm, user);

            assertThat(result).isFalse();
        }

        @Test
        @DisplayName("should return true when user has SMS credential")
        void shouldReturnTrueWhenUserHasSmsCredential() {
            CredentialModel model = new CredentialModel();
            try {
                model.setCredentialData(
                    org.keycloak.util.JsonSerialization.writeValueAsString(
                        new SmsAuthCredentialData("+491761234567")
                    )
                );
            } catch (IOException e) {
                throw new RuntimeException(e);
            }
            model.setType("mobile-number");

            when(user.credentialManager()).thenReturn(mock(org.keycloak.models.credential.UserCredentialStore.class));
            when(user.credentialManager().getStoredCredentialsByTypeStream("mobile-number"))
                .thenReturn(Stream.of(model));

            boolean result = authenticator.configuredFor(session, realm, user);

            assertThat(result).isTrue();
        }
    }

    @Nested
    @DisplayName("Lifecycle")
    class Lifecycle {

        @Test
        @DisplayName("should not throw exception on close")
        void shouldNotThrowExceptionOnClose() {
            authenticator.close();
            // Should not throw
        }
    }
}
